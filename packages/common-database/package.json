{
	"name": "common-database",
	"version": "0.1.0",
	"description": "Isolate database definition in its own package for reusability and separation of concerns",
	"private": true,
	"main": "dist/index.mjs",
	"types": "dist/index.d.ts",
	"keywords": [],
	"author": "taivo",
	"type": "module",
	"scripts": {
		"build": "tsup",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "wrangler d1 migrations apply DB",
		"db:migrate-prod": "pnpm db:migrate --remote",
		"db:studio": "drizzle-kit studio",
		"db:studio-prod": "NODE_ENV=production dotenvx run -- drizzle-kit studio"
	},
	"packageManager": "pnpm@10.10.0",
	"dependencies": {
		"drizzle-orm": "^0.43.1"
	},
	"engines": {
		"node": ">=22",
		"pnpm": ">=10"
	},
	"devDependencies": {
		"@dotenvx/dotenvx": "^1.44.0",
		"drizzle-kit": "^0.31.1",
		"drizzle-seed": "^0.3.1",
		"tsup": "^8.4.0",
		"typescript": "^5.8.3"
	}
}
